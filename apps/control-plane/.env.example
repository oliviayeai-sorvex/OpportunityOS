# Environment Variables Template
# Copy this file to .env and fill in the values for your local environment.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=local                            # local | staging | production
APP_SECRET_KEY=changeme-use-a-long-random-string
LOG_LEVEL=debug                          # debug | info | warn | error

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sonic_celestial
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
JWT_SECRET_KEY=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─────────────────────────────────────────────
# LLM / AI Provider
# ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=openai              # openai | anthropic

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=            # OpenTelemetry collector endpoint
SENTRY_DSN=                             # Sentry DSN for error tracking

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
